# Ananta AI worker — copy to .env and fill in real values

# Server
HOST=0.0.0.0
PORT=5000
ENV=development

# Database (Prisma writes here; we read + write embeddings)
DATABASE_URL=postgresql+asyncpg://ananta:ananta@localhost:5432/ananta

# Redis (Celery + cache)
REDIS_URL=redis://localhost:6379/0

# Groq (free tier — 30 req/min, 14k/day)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (fallback when Groq rate-limits)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Sarvam (Kanglish doubt answering)
SARVAM_API_KEY=

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RAG_TOP_K=8
RAG_RERANK_TO=4

# Callback to Nest API when a doubt answer is ready
API_URL=http://localhost:4000/v1
INTERNAL_SHARED_SECRET=change-me-to-32-chars-plus

# TTS (AI4Bharat IndicTTS)
TTS_PROVIDER=ai4bharat
TTS_VOICES_DIR=./models/voices
