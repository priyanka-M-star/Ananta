# Ananta API — copy this file to .env and fill in real values

# server
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# database (Prisma)
DATABASE_URL="postgresql://ananta:ananta@localhost:5432/ananta?schema=public"

# auth
JWT_SECRET="change-me-to-a-long-random-string-32-chars-plus"
JWT_EXPIRES_IN="7d"

# launch gate
LAUNCH_GATE_MIN_MEMBERS=10
LAUNCH_DATE=2026-07-01

# MSG91 (SMS OTP)
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="ANANTA"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# AI worker (FastAPI)
AI_WORKER_URL=http://localhost:5000
