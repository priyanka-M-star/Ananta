# Production env — copy to infra/prod.env on the Oracle VM and fill in.

# GitHub Container Registry image owner (lowercase your GitHub username/org)
GH_OWNER=your-gh-username
IMAGE_TAG=latest

# ---------- Postgres ----------
POSTGRES_USER=ananta
POSTGRES_PASSWORD=         # generate: openssl rand -base64 32
POSTGRES_DB=ananta
DATABASE_URL=postgresql://ananta:CHANGE_ME@postgres:5432/ananta?schema=public

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- App URLs ----------
WEB_ORIGIN=https://ananta.app
NEXT_PUBLIC_API_URL=https://api.ananta.app/v1
API_URL=https://api.ananta.app/v1
AI_WORKER_URL=http://ai-worker:5000

# ---------- Auth ----------
JWT_SECRET=                # generate: openssl rand -base64 48
JWT_EXPIRES_IN=7d

# ---------- Launch gate ----------
LAUNCH_GATE_MIN_MEMBERS=10
LAUNCH_DATE=2026-07-01

# ---------- MSG91 ----------
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=ANANTA

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- WhatsApp (Meta Cloud API) ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---------- LLM ----------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
SARVAM_API_KEY=

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ananta-assets
R2_PUBLIC_URL=https://assets.ananta.app

# ---------- LiveKit ----------
LIVEKIT_HOST=wss://livekit.ananta.app
LIVEKIT_API_KEY=           # `livekit-server generate-keys`
LIVEKIT_API_SECRET=

# ---------- Email (Resend) ----------
RESEND_API_KEY=
EMAIL_FROM=noreply@ananta.app

# ---------- Sentry ----------
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_WORKER=

# ---------- Cloudflare Tunnel ----------
CLOUDFLARE_TUNNEL_TOKEN=

# ---------- Internal AI worker shared secret ----------
INTERNAL_SHARED_SECRET=    # generate: openssl rand -base64 32
