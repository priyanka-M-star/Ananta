{
  "name": "ananta",
  "version": "0.1.0",
  "private": true,
  "description": "AI tutoring platform for Karnataka State Board — monorepo root",
  "author": "priyanka <priyankauru5@gmail.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @ananta/db prisma generate",
    "db:migrate": "pnpm --filter @ananta/db prisma migrate dev",
    "db:studio": "pnpm --filter @ananta/db prisma studio",
    "db:seed": "pnpm --filter @ananta/db tsx prisma/seed.ts",
    "db:seed:demo": "pnpm --filter @ananta/db tsx prisma/seed-demo.ts",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "@types/node": "^20.16.5"
  }
}
