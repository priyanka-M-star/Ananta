# ============================================================
# Ananta — Environment variables (root-level shared values)
# Copy this file to .env and fill in real values. Never commit .env.
# ============================================================

# ---------- Postgres ----------
DATABASE_URL="postgresql://ananta:ananta@localhost:5432/ananta?schema=public"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"

# ---------- App URLs ----------
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"
AI_WORKER_URL="http://localhost:5000"

# ---------- Auth ----------
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="change-me-too"

# ---------- MSG91 (SMS OTP) ----------
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="ANANTA"

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---------- WhatsApp (Meta Cloud API) ----------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# ---------- Groq (LLM) ----------
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# ---------- OpenRouter (fallback LLM) ----------
OPENROUTER_API_KEY=""

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ananta-assets"
R2_PUBLIC_URL="https://assets.ananta.app"

# ---------- LiveKit ----------
LIVEKIT_HOST="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="dev-secret-change-in-prod"

# ---------- Resend (Email) ----------
RESEND_API_KEY=""
EMAIL_FROM="noreply@ananta.app"

# ---------- Sentry ----------
SENTRY_DSN_WEB=""
SENTRY_DSN_API=""
SENTRY_DSN_WORKER=""

# ---------- PostHog ----------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ---------- Feature flags ----------
LAUNCH_GATE_MIN_MEMBERS=10
LAUNCH_DATE="2026-07-01"
ENABLE_LIVE_CLASSES=false
